{
  "name": "clinic-queue-mvp",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "clean:frontend": "npm run clean --workspace=frontend",
    "dev:frontend:clean": "npm run clean --workspace=frontend && npm run dev --workspace=frontend",
    "prisma:migrate": "npm run prisma:migrate --workspace=backend",
    "smoke:queue": "npm run smoke:queue --workspace=backend",
    "verify:queue": "npm run verify:queue --workspace=backend",
    "verify:smart-wait": "npm run verify:smart-wait --workspace=backend",
    "qa:verify": "npm run qa:verify --workspace=backend",
    "test": "npm run test --workspace=backend",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:chrome": "PLAYWRIGHT_USE_SYSTEM_CHROME=1 playwright test",
    "postinstall": "npm run prisma:generate --workspace=backend"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "concurrently": "^9.1.2"
  }
}
