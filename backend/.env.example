# SQLite (default for local dev — no Docker/Postgres)
DATABASE_URL="file:./dev.db"

# Optional: use PostgreSQL instead (then set provider to postgresql in prisma/schema.prisma and run migrations)
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/clinic_queue?schema=public"
PORT=4000
# Expose this port with a tunnel for Twilio (WhatsApp) webhooks. Test forwarding:
#   curl https://YOUR_PUBLIC_HOST/tunnel-check   → should return JSON { "ok": true, ... }
# Examples (run in a second terminal while the API is up):
#   cloudflared tunnel --url http://127.0.0.1:4000
#   npx localtunnel --port 4000
#   ngrok http 4000
# Twilio Sandbox "When a message comes in" URL: https://YOUR_PUBLIC_HOST/whatsapp-webhook  (HTTP POST)
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Optional: when set, staff-only routes require header X-Clinic-Key to match (GET /patient/lookup, GET /analytics, POST /broadcast, POST/PATCH/DELETE /doctors). Mirror in frontend NEXT_PUBLIC_CLINIC_STAFF_KEY.
# CLINIC_STAFF_API_KEY=change-me-in-production
# Optional: require the same key on Socket.io handshakes (set NEXT_PUBLIC_CLINIC_STAFF_KEY on doctor, patient, and display clients). Default off so TV kiosks work without a secret.
# SOCKET_IO_REQUIRE_STAFF=true
AVG_CONSULTATION_MINUTES=10
# IANA timezone for analytics (daily buckets + peak hour labels). Example: Asia/Kolkata, America/New_York
# CLINIC_TIMEZONE=Asia/Kolkata

# Default doctor when API omits doctorId (must match a Doctor.id; migration seeds clinic-default-doctor)
# DEFAULT_DOCTOR_ID=clinic-default-doctor
# Paste real Twilio credentials in backend/.env (not committed). Example shape:
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# Set to 1 to stop queue/patient outbound WhatsApp API sends (saves Twilio daily quota). Webhook still tries REST first.
# Twilio trial/sandbox WhatsApp is often ~50 outbound messages per day for the whole account. If you see "exceeded the 50 daily messages limit",
# wait for reset, upgrade, or use a subaccount; otherwise REST and TwiML replies can both fail.
# TWILIO_DISABLE_OUTBOUND_WHATSAPP=1

# Clinic automation (default on): position notifications + doctor-delay heads-up + no-show auto skip + visit follow-up WhatsApp
# CLINIC_JOBS_ENABLED=false
# CLINIC_JOBS_INTERVAL_MS=60000
# NO_SHOW_TIMEOUT_MINUTES=10
# Count of "coming soon" pings for patients behind the next-up slot (waiting positions 2, 3, …). Default 2.
# UPCOMING_NOTIFY_POSITIONS=2
# NOTIFICATION_FAILED_RETRY_COOLDOWN_MS=900000
# DOCTOR_DELAY_NOTIFY_COOLDOWN_MS=600000
# FOLLOW_UP_RETRY_COOLDOWN_MS=300000
# Pause between each recipient in POST /broadcast (ms). Reduces Twilio rate-limit risk.
# BROADCAST_MESSAGE_DELAY_MS=400
# Several Node processes sharing one DB: only one should run clinic jobs (set true for Postgres or shared SQLite)
# CLINIC_JOBS_USE_DB_LEASE=true
# CLINIC_JOB_LEASE_TTL_MS=90000
# CLINIC_JOBS_WORKER_ID=my-api-1
GEMINI_API_KEY=

# Optional: comma-separated model fallbacks (defaults try gemini-2.5-flash, then lite, then 2.0)
# GEMINI_MODEL=gemini-2.5-flash,gemini-2.5-flash-lite

# WhatsApp chatbot: facts Gemini can use (hours, address, policies). Optional but recommended.
CLINIC_CHATBOT_CONTEXT=Mon-Fri 9-5, Sat 9-1. 123 Main St. Walk-ins OK. Bring ID.

# Offline FAQ when user asks for hours but CLINIC_CHATBOT_CONTEXT is empty (optional; sensible defaults exist)
# DEFAULT_CLINIC_HOURS=Mon–Sat 9:00–18:00. Closed Sundays.
# DEFAULT_CLINIC_HOURS_HI=सोम–शनि 9–6 बजे। रविवार बंद।