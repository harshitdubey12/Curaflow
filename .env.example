# Copy to backend/.env and frontend/.env.local as needed

# Backend database (SQLite by default — zero install)
# DATABASE_URL is usually set in backend/.env as file:./dev.db

# Backend API
PORT=4000
NODE_ENV=development

# CORS: Next.js dev server
CORS_ORIGIN=http://localhost:3000

# Average consultation length in minutes (wait time estimate)
AVG_CONSULTATION_MINUTES=10

# Default doctor id (must exist in DB; migration seeds clinic-default-doctor)
# DEFAULT_DOCTOR_ID=clinic-default-doctor

# Twilio WhatsApp (optional for local dev; copy real values only into backend/.env, do not commit secrets)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Google Gemini: paste your key in backend/.env only. Leave empty to use offline FAQ + templates.
GEMINI_API_KEY=

# WhatsApp chatbot facts (must also be in backend/.env when you run the API from backend/)
CLINIC_CHATBOT_CONTEXT=Mon-Fri 9-5, Sat 9-1. 123 Main St. Walk-ins OK. Bring ID.

# Optional: offline FAQ default hours if CLINIC_CHATBOT_CONTEXT is empty (see backend/.env.example)
# DEFAULT_CLINIC_HOURS=
# DEFAULT_CLINIC_HOURS_HI=

# Frontend (Next.js) — must match API URL
NEXT_PUBLIC_API_URL=http://localhost:4000

# Optional: same secret on API as CLINIC_STAFF_API_KEY for staff routes (lookup, analytics, broadcast, doctor roster)
# NEXT_PUBLIC_CLINIC_STAFF_KEY=change-me-in-production
# If backend SOCKET_IO_REQUIRE_STAFF=true, this key is also sent on Socket.io (doctor, patient, display pages)

# Clinic automation (see backend/.env.example): NO_SHOW_TIMEOUT_MINUTES, UPCOMING_NOTIFY_POSITIONS, etc.
# Analytics: IANA timezone for daily counts and peak hours (e.g. Asia/Kolkata). Set in backend/.env.
# CLINIC_TIMEZONE=Asia/Kolkata
